# Copy this file to .env and fill in real values. Never commit .env itself.

# Google Cloud OAuth client (Credentials > Create Credentials > OAuth client ID > Desktop app)
# Consent screen User Type must be "Internal" (available because this runs under a
# Google Workspace org) so no Google app-verification review is required.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ID of the Shared Drive (not a regular folder) both users are members of.
# Find it in the Drive URL when the Shared Drive is open: drive.google.com/drive/folders/<THIS_PART>
GOOGLE_SHARED_DRIVE_ID=

# Anthropic API key, used for document extraction (tax cards, deeds, etc.)
CLAUDE_API_KEY=
